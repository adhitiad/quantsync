# ==========================================
# QUANTSYNC LOCAL TESTING ENVIRONMENT
# ==========================================

# 1. GATEWAY & NETWORK PORTS
WSS_PORT=8443
GRPC_PORT=50051
JWT_SECRET=super_secret_ed25519_key_for_local_testing

# 2. SUPABASE POSTGRES
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# 3. CHROMADB CLOUD
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=782fe07d-6acd-49a1-9b8d-675058636079
CHROMA_DATABASE=Orojackson

# 4. NVIDIA AI ENDPOINTS
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# NOTE: API Keys untuk Telegram, WhatsApp, dan SMTP harus dikonfigurasi
# langsung di database (Supabase) sesuai instruksi "Zero .env Token" (Fase 21).
